# Copy this file to `.env` before running the monorepo locally.

# PostgreSQL database for Prisma and the workforce API.
POSTGRES_URL="postgresql://postgres:postgres@localhost:5432/workforcepro"

# Clerk authentication.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key"
NEXT_PUBLIC_CLERK_FRONTEND_API_URL="https://your-app.clerk.accounts.dev"
CLERK_SECRET_KEY="sk_test_your_secret_key"
CLERK_API_URL="https://api.clerk.com"

# Optional Expo override. When omitted, the Expo app will infer the local Next.js host.
EXPO_PUBLIC_API_URL="http://localhost:3000"
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key"
EXPO_PUBLIC_CLERK_FRONTEND_API_URL="https://your-app.clerk.accounts.dev"
