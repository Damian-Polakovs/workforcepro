{
  "name": "@workforcepro/mobile",
  "private": true,
  "main": "index.ts",
  "engines": {
    "node": ">=22.21.0 <26",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "dev": "node ./scripts/start-expo-dev.mjs --dev-client",
    "dev:android": "node ./scripts/start-expo-dev.mjs --dev-client --android",
    "dev:client": "node ./scripts/start-expo-dev.mjs --dev-client",
    "dev:ios": "node ./scripts/start-expo-dev.mjs --dev-client --ios",
    "dev:tunnel": "node ./scripts/start-expo-dev.mjs --dev-client --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "format": "prettier --check . --ignore-path .gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/expo": "^3.2.2",
    "@expo/metro-runtime": "^6.1.2",
    "@legendapp/list": "^2.0.14",
    "@tanstack/react-query": "^5.90.8",
    "@trpc/client": "^11.7.1",
    "@trpc/server": "^11.7.1",
    "@trpc/tanstack-react-query": "^11.7.1",
    "expo": "~54.0.20",
    "expo-auth-session": "~7.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "~6.0.16",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.13",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.8",
    "nativewind": "5.0.0-preview.2",
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "react-native": "~0.81.5",
    "react-native-css": "3.0.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.3",
    "react-native-safe-area-context": "~5.6.1",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "~0.5.1",
    "superjson": "2.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.16",
    "@types/react": "~19.1.0",
    "eslint": "^9.38.0",
    "lightningcss": "1.30.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3"
  }
