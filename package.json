{
  "name": "workforcepro-monorepo",
  "private": true,
  "engines": {
    "node": ">=22.21.0 <26",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:generate": "pnpm -F @acme/db generate",
    "db:push": "pnpm -F @acme/db push",
    "db:seed": "pnpm -F @acme/db seed",
    "db:studio": "pnpm -F @acme/db studio",
    "dev": "node ./scripts/dev-all.mjs",
    "dev:all": "pnpm dev",
    "dev:backend": "pnpm -F @acme/nextjs dev",
    "dev:client": "pnpm -F @workforcepro/mobile dev:client",
    "dev:frontend": "pnpm -F @workforcepro/mobile dev",
    "dev:mobile": "pnpm -F @workforcepro/mobile dev",
    "dev:next": "pnpm -F @acme/nextjs dev",
    "dev:tunnel": "node ./scripts/dev-all.mjs --tunnel",
    "dev:mobile:tunnel": "pnpm -F @workforcepro/mobile dev:tunnel",
    "eas:android:dev": "pnpm --dir apps/workforcepro-mobile exec eas build -p android --profile development",
    "eas:android:preview": "pnpm --dir apps/workforcepro-mobile exec eas build -p android --profile preview",
    "eas:android:production": "pnpm --dir apps/workforcepro-mobile exec eas build -p android --profile production",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:mobile": "pnpm -F @workforcepro/mobile lint",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "typecheck": "turbo run typecheck",
    "typecheck:mobile": "pnpm -F @workforcepro/mobile typecheck"
  },
  "devDependencies": {
    "@acme/prettier-config": "workspace:*",
    "dotenv-cli": "^10.0.0",
    "prettier": "catalog:",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config"
}
