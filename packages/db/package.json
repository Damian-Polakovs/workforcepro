{
  "name": "@acme/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./src/schema.ts"
    },
    "./demo": {
      "types": "./dist/demo.d.ts",
      "default": "./src/demo.ts"
    },
    "./workforce": {
      "types": "./dist/workforce.d.ts",
      "default": "./src/workforce.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "generate": "pnpm with-env prisma generate --schema prisma/schema.prisma",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "push": "pnpm with-env prisma db push --schema prisma/schema.prisma",
    "seed": "pnpm with-env tsx prisma/seed.ts",
    "studio": "pnpm with-env prisma studio --schema prisma/schema.prisma",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@acme/validators": "workspace:*",
    "@prisma/client": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prisma": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config"
}
